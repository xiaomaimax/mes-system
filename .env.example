# 服务器配置
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mes_system
DB_USER=root
DB_PASSWORD=

# Redis 配置（P2-1 缓存优化）
REDIS_URL=redis://localhost:6379

# JWT 配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE=7d

# 日志配置
LOG_LEVEL=info

# 监控配置（P2-2 监控优化）
SLOW_QUERY_THRESHOLD=1000
ENABLE_MONITORING=true
