NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000

# 数据库配置（本地测试用内存或跳过）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mes_system
DB_USER=root
DB_PASSWORD=

# Redis 配置（使用生产环境 Redis）
REDIS_URL=redis://:redis@192.168.100.6:6379

# JWT 配置
JWT_SECRET=test-secret-key
JWT_EXPIRE=7d

# 日志配置
LOG_LEVEL=debug

# 监控配置
SLOW_QUERY_THRESHOLD=1000
ENABLE_MONITORING=true
